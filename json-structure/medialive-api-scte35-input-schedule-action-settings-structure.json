          },
          "description": "In fixed mode, enter the name of the input attachment that you want to use as a SCTE-35 input. (Don't enter the ID of the input.)\""
        }
      ]
    },
    "Mode": {
      "allOf": [
        {
          "$ref": "#/components/schemas/Scte35InputMode"
        },
        {
          "xml": {
            "name": "mode"
          },
